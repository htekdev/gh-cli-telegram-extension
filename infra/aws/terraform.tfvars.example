# Copy this file to terraform.tfvars and fill in your actual values.
# terraform.tfvars is gitignored and must never be committed.

region           = "us-east-1"
instance_type    = "t3.medium"
key_name         = "gh-copilot-openclaw-key"
allowed_ssh_cidr = "0.0.0.0/0"   # Restrict to your IP: "203.0.113.42/32"
volume_size      = 20
project_name     = "gh-copilot-cli-telegram-bridge"

gh_token             = "your-github-pat-here"
copilot_github_token = "your-copilot-github-token-here"
telegram_bot_token   = "your-telegram-bot-token-here"
exa_api_key          = "your-exa-api-key-here"
perplexity_api_key   = "your-perplexity-api-key-here"
youtube_api_key      = "your-youtube-api-key-here"
zernio_api_key       = "your-zernio-api-key-here"
