# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Optional: restrict to a specific chat ID (recommended for security)
# Send /start to your bot, then check logs to find your chat ID
TELEGRAM_CHAT_ID=

# CopilotClient SDK connection (optional)
# Set CLI_URL to connect to an existing headless Copilot CLI server
# If not set, the SDK auto-starts a CLI process
CLI_URL=
CLI_PORT=

# Cron scheduler (set to true to enable scheduled tasks from cron.json)
CRON_ENABLED=false

# Log level (debug, info, warn, error)
LOG_LEVEL=info
